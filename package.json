{
  "name": "wedding-app",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Свадебный лендинг-приглашение (Влад & Оля). React + Vite + MobX.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rsvp-fn": "node --test rsvp-function/index.test.js",
    "test:screens": "playwright test",
    "screens:update": "playwright test --update-snapshots",
    "parity": "node tools/parity.mjs"
  },
  "dependencies": {
    "mobx": "^6.13.5",
    "mobx-react-lite": "^4.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^15.11.7",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
